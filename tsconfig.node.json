{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "incremental": true,
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./*"],
      "src/*": ["./src/*"],
      "@assets/*": ["./src/assets/*"]
    },
    "types": ["node", "chrome-types"]
  },
  "include": [
    "package.json",
    "vite.config.ts",
    "vite.firefox.config.ts",
    "manifest.config.ts",
    "manifest.firefox.config.ts"
  ]
}
