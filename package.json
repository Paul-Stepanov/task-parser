{
  "description": "Browser extension for parsing Bitrix24 tasks and generating AI prompts",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.3.0",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/eslint": "^9.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.2.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/compiler-sfc": "^3.5.28",
    "@vueuse/core": "^14.2.1",
    "chalk": "^5.6.2",
    "chrome-types": "^0.1.415",
    "commander": "^14.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "get-installed-browsers": "^0.1.7",
    "globals": "^17.3.0",
    "lodash-es": "^4.18.1",
    "marked": "^17.0.2",
    "pinia": "^3.0.4",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "terser": "^5.46.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "unplugin-imagemin": "^0.7.0",
    "vite": "^7.3.1",
    "vite-plugin-zip-pack": "^1.2.4",
    "vue": "^3.5.28",
    "vue-router": "^5.0.0",
    "vue-tsc": "^3.2.4",
    "web-ext": "^9.3.0"
  },
  "displayName": " Bitrix24 Task parser",
  "name": "vite-vue3-browser-extension-v3",
  "overrides": {
    "@crxjs/vite-plugin": "$@crxjs/vite-plugin"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Paul-Stepanov/task-parser"
  },
  "scripts": {
    "build": "npm run build:chrome",
    "build:chrome": "cross-env NODE_ENV=production vite build -c vite.chrome.config.ts",
    "dev": "npm run dev:chrome",
    "dev:chrome": "cross-env NODE_ENV=development vite -c vite.chrome.config.ts",
    "format": "prettier --write .",
    "lint": "eslint . --fix --cache",
    "lint:manifest": "web-ext lint --pretty",
    "typecheck": "vue-tsc --noEmit"
  },
  "type": "module",
  "version": "0.0.1"
}
